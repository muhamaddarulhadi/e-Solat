<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#16a34a"/>
      <stop offset="100%" style="stop-color:#065f46"/>
    </linearGradient>
    <linearGradient id="glow" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#4ade80;stop-opacity:0.3"/>
      <stop offset="100%" style="stop-color:#059669;stop-opacity:0"/>
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="512" height="512" rx="120" fill="url(#bg)"/>
  <rect width="512" height="512" rx="120" fill="url(#glow)"/>

  <!-- Mosque silhouette -->
  <!-- Main dome -->
  <ellipse cx="256" cy="200" rx="80" ry="75" fill="rgba(255,255,255,0.95)"/>
  <!-- Main body -->
  <rect x="176" y="270" width="160" height="120" rx="4" fill="rgba(255,255,255,0.95)"/>

  <!-- Side minarets -->
  <rect x="140" y="220" width="28" height="170" rx="4" fill="rgba(255,255,255,0.9)"/>
  <ellipse cx="154" cy="218" rx="16" ry="22" fill="rgba(255,255,255,0.9)"/>
  <rect x="148" y="196" width="12" height="16" rx="2" fill="rgba(255,255,255,0.9)"/>

  <rect x="344" y="220" width="28" height="170" rx="4" fill="rgba(255,255,255,0.9)"/>
  <ellipse cx="358" cy="218" rx="16" ry="22" fill="rgba(255,255,255,0.9)"/>
  <rect x="352" y="196" width="12" height="16" rx="2" fill="rgba(255,255,255,0.9)"/>

  <!-- Arch windows -->
  <ellipse cx="256" cy="330" rx="28" ry="35" fill="rgba(22,163,74,0.7)"/>
  <rect x="228" y="345" width="56" height="45" fill="rgba(22,163,74,0.7)"/>

  <!-- Crescent on dome -->
  <path d="M256 145 a35 35 0 1 1 0.1 0Z" fill="none" stroke="rgba(251,191,36,0.9)" stroke-width="8"/>
  <circle cx="278" cy="155" r="26" fill="url(#bg)"/>
  <polygon points="256,125 260,138 274,138 262,146 267,160 256,152 245,160 250,146 238,138 252,138" fill="rgba(251,191,36,0.9)"/>

  <!-- Ground line -->
  <rect x="100" y="388" width="312" height="8" rx="4" fill="rgba(255,255,255,0.4)"/>
</svg>
